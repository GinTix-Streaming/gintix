# ─────────────────────────────────────────────────────────────
# GinTix environment configuration
# Copy to `.env.local` and fill in. NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────

# Public site URL (used for Stripe redirects, channel links, webhooks)
NEXT_PUBLIC_SITE_URL=https://gintix.com

# ── Supabase ──────────────────────────────────────────────────
# Client-safe (exposed to browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Server-only. Bypasses RLS — keep secret, never prefix with NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ── Livepeer Studio (video ingest / transcode / multistream) ──
# Master server token from https://livepeer.studio/dashboard/developers/api-keys
LIVEPEER_API_KEY=YOUR_LIVEPEER_API_KEY
LIVEPEER_API_URL=https://livepeer.studio/api
# Public playback host for HLS URLs
NEXT_PUBLIC_LIVEPEER_PLAYBACK_HOST=https://lp-playback.studio

# ── Stripe (passes + multistream SaaS) ────────────────────────
STRIPE_SECRET_KEY=sk_live_or_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Price IDs created in the Stripe dashboard
STRIPE_PRICE_PREMIUM_AD_FREE=price_xxx_premium_viewer
STRIPE_PRICE_MULTISTREAM_SAAS=price_xxx_multistream_29

# ── Google Ad Manager 360 / SpotX (VAST/VMAP ad serving) ──────
# Public — these become part of the ad tag URL requested by the player.
NEXT_PUBLIC_GAM_NETWORK_CODE=YOUR_GAM_NETWORK_CODE
NEXT_PUBLIC_GAM_AD_UNIT=/YOUR_NETWORK/gintix/preroll
# Optional fallback VMAP endpoint
NEXT_PUBLIC_VMAP_AD_TAG_URL=
